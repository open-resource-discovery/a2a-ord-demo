exports[`demo.http > should match snapshot 1`] = `
"### ================================================================\\n### ORD Agent Discovery → A2A Communication\\n###\\n### Prerequisites: run demo/demo.sh\\n### ================================================================\\n\\n@spaceship = http://localhost:3001\\n@commander = http://localhost:3002\\n@ordProviderSuper = http://localhost:3004\\n\\n### ================================================================\\n### Part 1: ORD Discovery\\n### ================================================================\\n\\n### Step 1: ORD well-known entry point\\n\\n# @name ordWellKnown\\nGET {{spaceship}}/.well-known/open-resource-discovery\\nAccept: application/json\\n\\n### Step 2: ORD document — lists agents, apiResources, entityTypes\\n\\n@ordDocPath = {{ordWellKnown.response.body.openResourceDiscoveryV1.documents[0].url}}\\n\\n# @name ordDocument\\nGET {{spaceship}}{{ordDocPath}}\\nAccept: application/json\\n\\n### ================================================================\\n### Part 2: Super Agent ORD Discovery\\n### ================================================================\\n\\n### Step 3: Super Agent ORD well-known entry point\\n\\n# @name ordWellKnownSuper\\nGET {{ordProviderSuper}}/.well-known/open-resource-discovery\\nAccept: application/json\\n\\n### Step 4: Super Agent ORD document — the commander agent\\n\\n@ordDocPathSuper = {{ordWellKnownSuper.response.body.openResourceDiscoveryV1.documents[0].url}}\\n\\n# @name ordDocumentSuper\\nGET {{ordProviderSuper}}{{ordDocPathSuper}}\\nAccept: application/json\\n\\n### ================================================================\\n### Part 3: Agent Card → A2A Call\\n### ================================================================\\n\\n### Step 5: Fetch Repair Technician agent card\\n\\n# @name repairCard\\nGET {{spaceship}}/repair/agent.json\\nAccept: application/json\\n\\n### Step 6: Call Repair agent — \\"The engines are overheating!\\"\\n\\nPOST {{spaceship}}/repair\\nContent-Type: application/json\\n\\n{\\n  \\"jsonrpc\\": \\"2.0\\",\\n  \\"id\\": 1,\\n  \\"method\\": \\"message/send\\",\\n  \\"params\\": {\\n    \\"message\\": {\\n      \\"role\\": \\"user\\",\\n      \\"parts\\": [{\\"kind\\": \\"text\\", \\"text\\": \\"The engines are overheating!\\"}],\\n      \\"messageId\\": \\"demo-msg-1\\"\\n    }\\n  }\\n}\\n\\n### Step 7: Fetch Solar Explorer agent card\\n\\n# @name solarCard\\nGET {{spaceship}}/solar/agent.json\\nAccept: application/json\\n\\n### Step 8: Call Solar agent — \\"What's the weather like on Jupiter?\\"\\n\\nPOST {{spaceship}}/solar\\nContent-Type: application/json\\n\\n{\\n  \\"jsonrpc\\": \\"2.0\\",\\n  \\"id\\": 2,\\n  \\"method\\": \\"message/send\\",\\n  \\"params\\": {\\n    \\"message\\": {\\n      \\"role\\": \\"user\\",\\n      \\"parts\\": [{\\"kind\\": \\"text\\", \\"text\\": \\"What's the weather like on Jupiter?\\"}],\\n      \\"messageId\\": \\"demo-msg-2\\"\\n    }\\n  }\\n}\\n\\n### ================================================================\\n### Part 4: Commander — Automated ORD → A2A\\n###\\n### The commander reads ORD, discovers crew agents, delegates via A2A.\\n### ================================================================\\n\\n### Step 9: Commander agent card\\n\\n# @name commanderCard\\nGET {{commander}}/.well-known/agent.json\\nAccept: application/json\\n\\n### Step 10: Ask commander to handle a repair emergency\\n\\nPOST {{commander}}\\nContent-Type: application/json\\n\\n{\\n  \\"jsonrpc\\": \\"2.0\\",\\n  \\"id\\": 3,\\n  \\"method\\": \\"message/send\\",\\n  \\"params\\": {\\n    \\"message\\": {\\n      \\"role\\": \\"user\\",\\n      \\"parts\\": [{\\"kind\\": \\"text\\", \\"text\\": \\"Hull breach on deck 3! Shields are failing!\\"}],\\n      \\"messageId\\": \\"demo-msg-3\\"\\n    }\\n  }\\n}\\n\\n### Step 11: Ask commander a navigation question\\n\\nPOST {{commander}}\\nContent-Type: application/json\\n\\n{\\n  \\"jsonrpc\\": \\"2.0\\",\\n  \\"id\\": 4,\\n  \\"method\\": \\"message/send\\",\\n  \\"params\\": {\\n    \\"message\\": {\\n      \\"role\\": \\"user\\",\\n      \\"parts\\": [{\\"kind\\": \\"text\\", \\"text\\": \\"What's the weather on Mars? Can we land safely?\\"}],\\n      \\"messageId\\": \\"demo-msg-4\\"\\n    }\\n  }\\n}\\n\\n### ================================================================\\n### Part 5: A2A Editor Playground\\n###\\n### Try the full story in the visual A2A Editor:\\n###   https://open-resource-discovery.github.io/a2a-editor/playground\\n###\\n### 1. Click \\"+ Add\\" and enter:  http://localhost:3001/repair\\n### 2. Send: \\"The warp drive is making strange noises!\\"\\n### 3. Add another agent:        http://localhost:3001/solar\\n### 4. Send: \\"Tell me a fun fact about Saturn's rings\\"\\n### 5. Add the commander:        http://localhost:3002\\n### 6. Send: \\"We need to land on Mars, check the weather first!\\"\\n###    → Watch the commander discover agents via ORD and delegate.\\n### ================================================================\\n"
`;
